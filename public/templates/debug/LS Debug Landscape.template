  "author": "test",
  "templateVersion": "2.0.0",
  "formatVersion": 1,
  "categories": ["Debug"],
  "orientation": "landscape",
  "constants": [
    { "scaleX": "templateWidth / 1872" },
    { "scaleY": "templateHeight / 1404" },
    { "margin": "scaleX * 60" },
    { "cx": "templateWidth / 2" },
    { "cy": "templateHeight / 2" },
    { "crossLen": "scaleX * 40" },
    { "gsY": "scaleY * 160" },
    { "gsH": "scaleY * 55" },
    { "gsW": "scaleX * 200" },
    { "gsGap": "scaleX * 10" },
    { "gsStep": "gsW + gsGap" },
    { "g2Y": "gsY + gsH + scaleY * 16" },
    { "g3Y": "g2Y + gsH + scaleY * 16" },
    { "g4Y": "g3Y + gsH + scaleY * 16" },
    { "swY": "g4Y + gsH + scaleY * 40" },
    { "swLen": "templateWidth - margin * 2" },
    { "swSpacing": "scaleY * 18" },
    { "csY": "swY + swSpacing * 5 + scaleY * 30" },
    { "csH": "scaleY * 55" },
    { "csGap": "scaleX * 10" },
    { "csStep": "(templateWidth - margin * 2) / 9" },
    { "csW": "csStep - csGap" },
    { "bzY": "csY + csH + scaleY * 40" },
    { "bzH": "scaleY * 130" },
    { "pentCx": "margin + scaleX * 1040" },
    { "pentCy": "bzY + bzH / 2" },
    { "pentR": "(bzH - scaleY * 20) / 2" },
    { "txY": "bzY + bzH + scaleY * 25" },
    { "txStep": "scaleY * 58" },
    { "gridY": "txY + txStep * 5 + 10" },
    { "gridCellW": "(templateWidth - margin * 2) / 11" },
    { "gridCellH": "scaleY * 40" },
    { "gridRows": 3 },
    { "rlY": "gridY + gridCellH * gridRows + scaleY * 20" },
    { "rlSpacing": "scaleY * 30" },
    { "isRm2": "templateWidth > 1400 && templateHeight > 1300 ? 1 : 0" }
