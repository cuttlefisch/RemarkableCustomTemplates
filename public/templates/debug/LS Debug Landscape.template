      "boundingBox": { "x": "margin", "y": "gridY",
                       "width": "gridCellW", "height": "gridCellH" },
      "repeat": { "rows": 3, "columns": 11 },
      "children": [
        { "type": "path",
          "data": ["M",0,0,"L","parentWidth",0,"L","parentWidth","parentHeight","L",0,"parentHeight","Z"],
          "strokeColor": "#000000", "strokeWidth": 1 }
      ]
    },

    { "id": "label-rl", "type": "text",
      "text": "\u00a7J Repeat rows=down, cols=infinite", "fontSize": 16,
      "position": { "x": "margin", "y": "rlY - 20" } },
    { "id": "hlines", "type": "group",
      "boundingBox": { "x": "margin", "y": "rlY",
                       "width": "templateWidth - margin * 2", "height": "rlSpacing" },
      "repeat": { "rows": "down" },
      "children": [
        { "type": "path", "data": ["M",0,0,"L","parentWidth",0],
          "strokeColor": "#aaaaaa", "strokeWidth": 1 }
      ]
    },
    { "id": "vlines", "type": "group",
      "boundingBox": { "x": "paperOriginX", "y": "rlY",
                       "width": "rlSpacing", "height": "templateHeight - rlY - margin" },
      "repeat": { "columns": "infinite" },
      "children": [
        { "type": "path", "data": ["M",0,0,"L",0,"parentHeight"],
          "strokeColor": "#aaaaaa", "strokeWidth": 1 }
      ]
    }
  ]
}
