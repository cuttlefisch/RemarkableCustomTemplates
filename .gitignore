# Reference templates (device originals — not tracked, used for rendering verification)
remarkable_official_templates/*
!remarkable_official_templates/.gitkeep

# Official templates (reMarkable IP — serve from remarkable_official_templates/)
public/templates/*.template
public/templates/templates.json

# Custom user templates (user-local data)
public/templates/custom/

# Methods templates pulled from device
public/templates/methods/

# Server data (device config, SSH keys)
data/

# Server build output
dist-server/

# Node / web
node_modules/
dist/
dist-ssr/
dist-deploy/
rm-methods-dist/
rm-methods-backups/
.vite/
coverage/
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment
.env
.envrc
.venv
env/
venv/
